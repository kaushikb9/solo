# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Models — verify exact IDs at https://openrouter.ai/models
# Classification: cheap model, single-shot structured output
#   minimax/minimax-m2.7       ($0.30/$1.20 per M tokens — cheapest)
#   moonshotai/kimi-k2.5       ($0.44/$2.00 per M tokens — strong all-round)
#   moonshotai/kimi-k2.6       ($0.74/$3.49 per M tokens — best capability)
SOLO_CLASSIFY_MODEL=minimax/minimax-m2.7
# Expand/review (V1): needs strong reasoning
SOLO_EXPAND_MODEL=moonshotai/kimi-k2.6

# Local SQLite path. In prod this points to the Railway volume mount.
SOLO_DB_PATH=./data/solo.db

# Comma-separated Telegram chat IDs allowed to use the bot.
# Get yours from @userinfobot. Without this, anyone who finds the bot can talk to it.
SOLO_ALLOWED_CHATS=

# --- brain sync (optional; sync is disabled when these are unset) ---
# Private GitHub repo acting as the solo<->brain message bus, e.g. youruser/brain-sync
SOLO_SYNC_REPO=
# Fine-grained PAT scoped to ONLY that repo, with Contents read/write.
# Create at https://github.com/settings/personal-access-tokens/new
SOLO_GITHUB_TOKEN=
# When to deliver the morning briefing (hour 0-23, in SOLO_TZ)
SOLO_BRIEFING_HOUR=8
SOLO_TZ=Asia/Kolkata

# --- solo 2.0 multimodal capture ---
# Vision model for photo/screenshot description (must support image input)
SOLO_VISION_MODEL=google/gemini-2.5-flash
# Audio model for voice-note transcription (must support audio input via chat)
SOLO_AUDIO_MODEL=google/gemini-2.5-flash
# Where media lands on the Railway volume
SOLO_MEDIA_DIR=./data/media
# Local media is purged this many days after capture — but only once synced upstream
SOLO_MEDIA_RETENTION_DAYS=7
